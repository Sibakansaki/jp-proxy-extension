{
  "manifest_version": 3,
  "name": "JP Proxy",
  "version": "1.0",
  "description": "讓指定網站走日本 IP",
  "permissions": ["proxy", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["sites.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
